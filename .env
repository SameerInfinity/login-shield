# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── Brute-Force Detection ────────────────────────────────
FAILED_ATTEMPTS_THRESHOLD=5
FAILED_WINDOW_SECONDS=300

# ─── Baseline Behaviour ───────────────────────────────────
MIN_LOGINS_FOR_BASELINE=3

# ─── Login Frequency Anomaly ─────────────────────────────
MAX_LOGINS_IN_WINDOW=10
LOGIN_FREQUENCY_WINDOW_SECONDS=300

# ─── Concurrent Sessions ─────────────────────────────────
MAX_CONCURRENT_SESSIONS=3
SESSION_TIMEOUT_MINUTES=30

# ─── Geographic Anomaly ───────────────────────────────────
GEO_DISTANCE_THRESHOLD_KM=1000
GEO_TIME_THRESHOLD_MINUTES=120

# ─── Device Trust ────────────────────────────────────────
DEVICE_TRUST_LOGINS_THRESHOLD=5

# ─── Password Policy ─────────────────────────────────────
MIN_PASSWORD_LENGTH=8
REQUIRE_UPPERCASE=true
REQUIRE_NUMBERS=true
REQUIRE_SPECIAL=true

# ─── Risk Scoring ────────────────────────────────────────
RISK_SCORE_THRESHOLD=7
RISK_SCORE_DECAY_HOURS=24
RISK_POINTS_BRUTE_FORCE=3
RISK_POINTS_UNUSUAL_TIMING=1
RISK_POINTS_NEW_IP=2
RISK_POINTS_NEW_DEVICE=1
RISK_POINTS_NEW_LOCATION=2
RISK_POINTS_RAPID_LOGINS=2
RISK_POINTS_CONCURRENT_SESSION=1
RISK_POINTS_WEAK_PASSWORD=2

# ─── Splunk HEC ───────────────────────────────────────────
# Format: https://<your-instance>.splunkcloud.com:8088/services/collector/event
SPLUNK_HEC_URL=https://prd-p-8hy4f.splunkcloud.com:8088/services/collector/event
SPLUNK_HEC_TOKEN=dc1e8dfe-70b3-4572-939f-18e49f85f3b8